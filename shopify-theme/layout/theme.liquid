<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} – YELHA SKIN</title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

<nav class="site-nav">
  <ul class="nav-links">
    <li><a href="{{ routes.root_url }}" {% if request.path == '/' %}class="active"{% endif %}>Accueil</a></li>
    <li><a href="{{ routes.collections_url }}/masque-led" {% if request.path contains '/collections' %}class="active"{% endif %}>Catalogue</a></li>
    <li><a href="{{ routes.pages_url }}/contact" {% if request.path contains '/contact' %}class="active"{% endif %}>Contact</a></li>
  </ul>

  <div class="nav-logo">
    <a href="{{ routes.root_url }}">
      {% if settings.logo %}
        <img src="{{ settings.logo | img_url: '200x' }}" alt="{{ shop.name }}">
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}">
      {% endif %}
    </a>
  </div>

  <a href="{{ routes.all_products_collection_url }}/masque-led-yelha-skin" class="nav-cart">
    Acheter · {{ 2999 | money }}
  </a>
</nav>

<main>
  {{ content_for_layout }}
</main>

<footer>
  <div class="footer-logo">
    {% if settings.logo %}
      <img src="{{ settings.logo | img_url: '160x' }}" alt="{{ shop.name }}">
    {% else %}
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}">
    {% endif %}
  </div>
  <div class="footer-links">
    <a href="{{ routes.root_url }}">Accueil</a>
    <a href="{{ routes.collections_url }}/masque-led">Catalogue</a>
    <a href="{{ routes.pages_url }}/contact">Contact</a>
    <a href="{{ routes.pages_url }}/mentions-legales">Mentions légales</a>
    <a href="{{ routes.pages_url }}/politique-de-confidentialite">Confidentialité</a>
  </div>
  <p>© {{ 'now' | date: '%Y' }} YELHA SKIN. Tous droits réservés.</p>
</footer>

<script>
  // Accordion
  document.querySelectorAll('.acc-head').forEach(h => {
    h.addEventListener('click', () => {
      h.closest('.acc-item').classList.toggle('open');
    });
  });
  // Gallery thumbs
  document.querySelectorAll('.thumb').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.thumb').forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      const src = t.querySelector('img').src;
      const main = document.querySelector('.gallery-main img');
      if(main) main.src = src;
    });
  });
  // Qty
  document.querySelectorAll('.qbtn').forEach(b => {
    b.addEventListener('click', () => {
      const inp = b.closest('.qty-ctrl').querySelector('.qnum');
      let v = parseInt(inp.value) || 1;
      if(b.dataset.dir === '+') v++;
      else if(v > 1) v--;
      inp.value = v;
    });
  });
</script>

</body>
</html>
