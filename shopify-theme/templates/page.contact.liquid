<!-- CONTACT PAGE -->
<div class="contact-page">
  <div class="contact-card">
    <img class="contact-logo" src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}">
    <h2>Contactez-nous</h2>
    <p>Une question sur votre commande, un conseil beauté ou simplement envie d'échanger ? Notre équipe vous répond sous 24h.</p>

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <p style="color:green;padding:12px;background:#f0fff0;margin-bottom:16px;">✓ Message envoyé ! Nous vous répondrons dans les 24h.</p>
      {% endif %}
      {% if form.errors %}
        <p style="color:red;padding:12px;background:#fff0f0;margin-bottom:16px;">{{ form.errors | default_errors }}</p>
      {% endif %}

      <div class="contact-form">
        <input type="text" name="contact[name]" placeholder="Votre nom" value="{{ form.name }}" required>
        <input type="email" name="contact[email]" placeholder="Votre email" value="{{ form.email }}" required>
        <input type="text" name="contact[phone]" placeholder="Téléphone (optionnel)" value="{{ form.phone }}">
        <textarea name="contact[body]" placeholder="Votre message...">{{ form.body }}</textarea>
        <button type="submit">Envoyer le message</button>
      </div>
    {% endform %}

    <div class="contact-social">📸 Instagram: @yelhaskin &nbsp;|&nbsp; 📧 contact@yelhaskin.com</div>
    <div class="contact-hours">Lun–Ven : 9h–18h · Réponse sous 24h</div>
  </div>
</div>
